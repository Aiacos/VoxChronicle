{{!--
  VoxChronicle - Session Recorder Template

  Handlebars template for the RecorderControls Application.
  Provides UI for starting, stopping, pausing, and managing session recordings.

  @module vox-chronicle
  @template recorder
--}}

<div class="vox-chronicle-recorder">
  {{!-- Status indicator section --}}
  <div class="vox-chronicle-recorder-status {{statusClass}}">
    <span class="vox-chronicle-status-indicator"></span>
    <span class="vox-chronicle-status-text">{{statusText}}</span>
  </div>

  {{!-- Transcription Mode Indicator --}}
  {{#if showModeIndicator}}
  <div class="vox-chronicle-recorder-mode-indicator">
    <span class="vox-chronicle-mode-label">{{i18n.transcriptionMode}}:</span>
    <span class="vox-chronicle-mode-badge {{modeClass}} {{healthClass}}" title="{{modeTooltip}}">
      {{modeLabel}}
      {{#if healthStatus}}
        {{#if (eq healthStatus "connected")}}
          <i class="fa-solid fa-check-circle vox-chronicle-health-icon" title="{{i18n.localBackendConnected}}"></i>
        {{else if (eq healthStatus "checking")}}
          <i class="fa-solid fa-spinner fa-pulse vox-chronicle-health-icon" title="{{i18n.localBackendChecking}}"></i>
        {{else}}
          <i class="fa-solid fa-exclamation-circle vox-chronicle-health-icon" title="{{i18n.localBackendUnavailable}}"></i>
        {{/if}}
      {{/if}}
    </span>
  </div>
  {{/if}}

  {{!-- Duration display --}}
  <div class="vox-chronicle-recorder-duration">
    <span class="vox-chronicle-duration-label">{{i18n.duration}}:</span>
    <span class="vox-chronicle-duration-value" data-duration="{{durationSeconds}}">{{duration}}</span>
  </div>

  {{!-- Progress bar (shown during processing) --}}
  {{#if hasProgress}}
  <div class="vox-chronicle-recorder-progress">
    <div class="vox-chronicle-progress-bar"
         role="progressbar"
         aria-valuenow="{{progress.progress}}"
         aria-valuemin="0"
         aria-valuemax="100"
         aria-label="{{progress.message}}">
      <div class="vox-chronicle-progress-fill" style="width: {{progress.progress}}%"></div>
    </div>
    <span class="vox-chronicle-progress-text">{{progress.message}}</span>
  </div>
  {{/if}}

  {{!-- Error display --}}
  {{#if isError}}
  <div class="vox-chronicle-recorder-error">
    <i class="fa-solid fa-exclamation-circle"></i>
    <span>{{lastError}}</span>
  </div>
  {{/if}}

  {{!-- Control buttons --}}
  <div class="vox-chronicle-recorder-controls">
    {{!-- Start Recording button (shown when idle) --}}
    {{#if canRecord}}
    <button type="button"
            class="vox-chronicle-btn-record"
            data-action="start-recording"
            title="{{i18n.startRecording}}"
            {{#unless isConfigured}}disabled{{/unless}}>
      <i class="fa-solid fa-microphone"></i>
      <span>{{i18n.startRecording}}</span>
    </button>
    {{/if}}

    {{!-- Pause button (shown when recording) --}}
    {{#if canPause}}
    <button type="button"
            class="vox-chronicle-btn-pause"
            data-action="pause-recording"
            title="{{i18n.pauseRecording}}"
            aria-label="{{i18n.pauseRecording}}">
      <i class="fa-solid fa-pause"></i>
    </button>
    {{/if}}

    {{!-- Resume button (shown when paused) --}}
    {{#if canResume}}
    <button type="button"
            class="vox-chronicle-btn-resume"
            data-action="resume-recording"
            title="{{i18n.resumeRecording}}"
            aria-label="{{i18n.resumeRecording}}">
      <i class="fa-solid fa-play"></i>
    </button>
    {{/if}}

    {{!-- Stop Recording button (shown when recording or paused) --}}
    {{#if canStop}}
    <button type="button"
            class="vox-chronicle-btn-stop"
            data-action="stop-recording"
            title="{{i18n.stopRecording}}">
      <i class="fa-solid fa-stop"></i>
      <span>{{i18n.stopRecording}}</span>
    </button>
    {{/if}}

    {{!-- Cancel button (shown when recording or paused) --}}
    {{#if canStop}}
    <button type="button"
            class="vox-chronicle-btn-cancel"
            data-action="cancel-session"
            title="{{i18n.cancelSession}}"
            aria-label="{{i18n.cancelSession}}">
      <i class="fa-solid fa-times"></i>
    </button>
    {{/if}}
  </div>

  {{!-- Configuration warning (shown when not configured) --}}
  {{#unless isConfigured}}
  <div class="vox-chronicle-recorder-warning">
    <i class="fa-solid fa-exclamation-triangle"></i>
    <span>{{i18n.notConfigured}}</span>
    <button type="button" class="vox-chronicle-btn-settings" data-action="open-settings">
      <i class="fa-solid fa-cog"></i>
      <span>{{i18n.settings}}</span>
    </button>
  </div>
  {{/unless}}

  {{!-- Configuration status indicators --}}
  {{#if isConfigured}}
  <div class="vox-chronicle-recorder-config-status">
    <span class="vox-chronicle-config-item {{#if isOpenAIConfigured}}configured{{else}}missing{{/if}}" title="OpenAI API">
      <i class="fa-solid fa-{{#if isOpenAIConfigured}}check-circle{{else}}exclamation-circle{{/if}}"></i>
      <span>OpenAI</span>
    </span>
    <span class="vox-chronicle-config-item {{#if isKankaConfigured}}configured{{else}}optional{{/if}}" title="Kanka API">
      <i class="fa-solid fa-{{#if isKankaConfigured}}check-circle{{else}}minus-circle{{/if}}"></i>
      <span>Kanka</span>
    </span>
  </div>
  {{/if}}

  {{!-- Session summary (shown after recording) --}}
  {{#if sessionSummary}}
  <div class="vox-chronicle-recorder-session-summary">
    <div class="vox-chronicle-summary-item">
      <span class="vox-chronicle-summary-label">{{i18n.segments}}</span>
      <span class="vox-chronicle-summary-value">{{sessionSummary.segmentCount}}</span>
    </div>
    {{#if sessionSummary.speakerCount}}
    <div class="vox-chronicle-summary-item">
      <span class="vox-chronicle-summary-label">{{i18n.speakers}}</span>
      <span class="vox-chronicle-summary-value">{{sessionSummary.speakerCount}}</span>
    </div>
    {{/if}}
  </div>
  {{/if}}
</div>
