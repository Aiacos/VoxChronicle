{{!--
  VoxChronicle - Relationship Graph Template

  Handlebars template for the RelationshipGraph Application.
  Provides interactive visualization of entity relationships extracted from
  session transcripts using vis-network library.

  @module vox-chronicle
  @template relationship-graph
--}}

{{!-- All CSS classes prefixed with vox-chronicle- to prevent Foundry DOM collisions. --}}
<div class="vox-chronicle-relationship-graph">

  {{!-- Error state --}}
  {{#if isError}}
  <div class="vox-chronicle-graph-error">
    <i class="fa-solid fa-exclamation-triangle"></i>
    <p>{{localize "VOXCHRONICLE.RelationshipGraph.ErrorMessage"}}</p>
  </div>
  {{/if}}

  {{!-- Empty state --}}
  {{#if isEmpty}}
  <div class="vox-chronicle-graph-empty">
    <i class="fa-solid fa-project-diagram"></i>
    <p>{{localize "VOXCHRONICLE.RelationshipGraph.NoRelationships"}}</p>
    <p class="vox-chronicle-empty-hint">{{localize "VOXCHRONICLE.RelationshipGraph.NoRelationshipsHint"}}</p>
  </div>
  {{/if}}

  {{!-- Main graph visualization area --}}
  {{#if isReady}}
  <div class="vox-chronicle-graph-visualization">

    {{!-- Toolbar with controls --}}
    <div class="vox-chronicle-graph-toolbar">
      <div class="vox-chronicle-toolbar-section vox-chronicle-filter-controls">
        <label class="vox-chronicle-filter-label">
          <span>{{localize "VOXCHRONICLE.RelationshipGraph.FilterByEntity"}}:</span>
          <select data-filter="entity-type">
            {{#each entityTypeOptions}}
            <option value="{{value}}" {{#if (eq value ../filters.entityType)}}selected{{/if}}>
              {{label}}{{#if count}} ({{count}}){{/if}}
            </option>
            {{/each}}
          </select>
        </label>

        <label class="vox-chronicle-filter-label">
          <span>{{localize "VOXCHRONICLE.RelationshipGraph.FilterByRelation"}}:</span>
          <select data-filter="relationship-type">
            {{#each relationshipTypeOptions}}
            <option value="{{value}}" {{#if (eq value ../filters.relationshipType)}}selected{{/if}}>
              {{label}}{{#if count}} ({{count}}){{/if}}
            </option>
            {{/each}}
          </select>
        </label>
      </div>

      <div class="vox-chronicle-toolbar-section vox-chronicle-action-controls">
        <button type="button"
                class="vox-chronicle-btn-action"
                data-action="refresh"
                title="{{localize 'VOXCHRONICLE.RelationshipGraph.Refresh'}}">
          <i class="fa-solid fa-sync"></i>
          <span>{{localize "VOXCHRONICLE.RelationshipGraph.Refresh"}}</span>
        </button>
        <button type="button"
                class="vox-chronicle-btn-action"
                data-action="export"
                title="{{localize 'VOXCHRONICLE.RelationshipGraph.Export'}}">
          <i class="fa-solid fa-download"></i>
          <span>{{localize "VOXCHRONICLE.RelationshipGraph.Export"}}</span>
        </button>
      </div>
    </div>

    {{!-- Graph container (vis-network renders here) --}}
    <div class="vox-chronicle-graph-container" id="relationship-graph-network">
      {{!-- vis-network will create the graph here --}}
    </div>

    {{!-- Legend panel --}}
    <div class="vox-chronicle-graph-legend">
      <div class="vox-chronicle-legend-header">
        <span class="vox-chronicle-legend-title">{{localize "VOXCHRONICLE.RelationshipGraph.Legend"}}</span>
      </div>
      <div class="vox-chronicle-legend-content">
        <div class="vox-chronicle-legend-section">
          <div class="vox-chronicle-legend-section-title">{{localize "VOXCHRONICLE.RelationshipGraph.RelationshipTypes"}}</div>
          {{#each legendItems}}
          <div class="vox-chronicle-legend-item">
            <div class="vox-chronicle-legend-edge" style="background-color: {{color}};"></div>
            <span>{{label}}</span>
          </div>
          {{/each}}
        </div>
      </div>
    </div>

  </div>

  {{!-- Footer with stats and actions --}}
  <div class="vox-chronicle-graph-footer">
    <div class="vox-chronicle-graph-stats">
      <span class="vox-chronicle-stat-item">
        <i class="fa-solid fa-circle"></i>
        <span>{{totalEntities}} {{localize "VOXCHRONICLE.RelationshipGraph.Entities"}}</span>
      </span>
      <span class="vox-chronicle-stat-item">
        <i class="fa-solid fa-arrows-alt-h"></i>
        <span>{{totalRelationships}} {{localize "VOXCHRONICLE.RelationshipGraph.Relationships"}}</span>
      </span>
    </div>
    <div class="vox-chronicle-graph-actions">
      <button type="button"
              class="vox-chronicle-btn-close"
              data-action="close">
        <i class="fa-solid fa-times"></i>
        <span>{{localize "VOXCHRONICLE.RelationshipGraph.Close"}}</span>
      </button>
    </div>
  </div>
  {{/if}}

</div>
