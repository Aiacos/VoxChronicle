{{!--
  VoxChronicle - Entity Preview Template

  Handlebars template for the EntityPreview Application.
  Provides UI for reviewing extracted entities (characters, locations, items)
  before publishing them to Kanka.

  @module vox-chronicle
  @template entity-preview
--}}

<div class="vox-chronicle-entity-preview">
  {{!-- Description section --}}
  <div class="vox-chronicle-preview-description">
    <p>{{i18n.description}}</p>
  </div>

  {{!-- Configuration warning (shown when Kanka is not configured) --}}
  {{#unless isKankaConfigured}}
  <div class="vox-chronicle-preview-warning">
    <i class="fa-solid fa-exclamation-triangle"></i>
    <span>{{i18n.notConfigured}}</span>
  </div>
  {{/unless}}

  {{!-- Progress section (shown during entity creation) --}}
  {{#if hasProgress}}
  <div class="vox-chronicle-entity-preview-progress">
    <div class="vox-chronicle-progress-message">{{progress.message}}</div>
    <div class="vox-chronicle-progress-bar">
      <div class="vox-chronicle-progress-fill" style="width: {{progress.percent}}%"></div>
    </div>
    <div class="vox-chronicle-progress-count">{{progress.current}} / {{progress.total}}</div>
  </div>
  {{/if}}

  {{!-- Results section (shown after entity creation) --}}
  {{#if hasResults}}
  <div class="vox-chronicle-entity-preview-results {{#if isError}}vox-chronicle-error{{else}}vox-chronicle-success{{/if}}">
    <div class="vox-chronicle-results-summary">
      {{#if createdCount}}
      <div class="vox-chronicle-created-count">
        <i class="fa-solid fa-check"></i>
        <span>{{i18n.created}}</span>
      </div>
      {{/if}}
      {{#if failedCount}}
      <div class="vox-chronicle-failed-count">
        <i class="fa-solid fa-times"></i>
        <span>{{i18n.failedCountLabel}}</span>
      </div>
      {{/if}}
    </div>
    {{#if failedCount}}
    <div class="vox-chronicle-failed-entities">
      {{#each results.failed}}
      <div class="vox-chronicle-failed-entity">
        <span class="vox-chronicle-failed-type">{{type}}:</span>
        <span class="vox-chronicle-failed-name">{{name}}</span>
        <span class="vox-chronicle-failed-error">- {{error}}</span>
      </div>
      {{/each}}
    </div>
    {{/if}}
  </div>
  {{/if}}

  {{!-- Entity sections (shown in review mode) --}}
  {{#if isReview}}
    {{#if hasEntities}}
    <div class="vox-chronicle-entity-sections">

      {{!-- Characters section --}}
      {{#if hasCharacters}}
      <div class="vox-chronicle-entity-section">
        <div class="vox-chronicle-section-header" data-action="toggle-section">
          <i class="fa-solid fa-chevron-down vox-chronicle-section-toggle"></i>
          <span class="vox-chronicle-section-title">{{i18n.characters}}</span>
          <span class="vox-chronicle-section-count">({{characters.length}})</span>
        </div>
        <div class="vox-chronicle-section-content">
          {{#each characters}}
          <div class="vox-chronicle-entity-row {{#if selected}}vox-chronicle-selected{{/if}}">
            <div class="vox-chronicle-entity-select">
              <input type="checkbox"
                     data-entity-key="{{key}}"
                     {{#if selected}}checked{{/if}} />
            </div>
            <div class="vox-chronicle-entity-info">
              <div class="vox-chronicle-entity-name">{{name}}</div>
              <div class="vox-chronicle-entity-type">{{typeLabel}}</div>
              {{#if description}}
              <div class="vox-chronicle-entity-description">{{description}}</div>
              {{/if}}
            </div>
            <div class="vox-chronicle-entity-actions">
              <button type="button"
                      class="vox-chronicle-btn-edit"
                      data-action="edit-description"
                      data-entity-type="characters"
                      data-entity-index="{{index}}"
                      title="{{../i18n.editDescription}}">
                <i class="fa-solid fa-edit"></i>
              </button>
              <button type="button"
                      class="vox-chronicle-btn-generate"
                      data-action="generate-portrait"
                      data-entity-type="characters"
                      data-entity-index="{{index}}"
                      {{#if isGeneratingImage}}disabled{{/if}}
                      title="{{../i18n.generatePortrait}}">
                <i class="fa-solid {{#if isGeneratingImage}}fa-spinner fa-spin{{else}}fa-image{{/if}}"></i>
              </button>
            </div>
            {{#if isGeneratingImage}}
            <div class="vox-chronicle-entity-image-placeholder">
              <i class="fa-solid fa-spinner fa-spin"></i>
              <span class="vox-chronicle-placeholder-text">{{../i18n.generating}}</span>
            </div>
            {{else}}
              {{#if imageUrl}}
              <div class="vox-chronicle-entity-preview-image">
                <img src="{{imageUrl}}" alt="{{name}}" />
              </div>
              {{/if}}
            {{/if}}
          </div>
          {{/each}}
        </div>
      </div>
      {{/if}}

      {{!-- Locations section --}}
      {{#if hasLocations}}
      <div class="vox-chronicle-entity-section">
        <div class="vox-chronicle-section-header" data-action="toggle-section">
          <i class="fa-solid fa-chevron-down vox-chronicle-section-toggle"></i>
          <span class="vox-chronicle-section-title">{{i18n.locations}}</span>
          <span class="vox-chronicle-section-count">({{locations.length}})</span>
        </div>
        <div class="vox-chronicle-section-content">
          {{#each locations}}
          <div class="vox-chronicle-entity-row {{#if selected}}vox-chronicle-selected{{/if}}">
            <div class="vox-chronicle-entity-select">
              <input type="checkbox"
                     data-entity-key="{{key}}"
                     {{#if selected}}checked{{/if}} />
            </div>
            <div class="vox-chronicle-entity-info">
              <div class="vox-chronicle-entity-name">{{name}}</div>
              <div class="vox-chronicle-entity-type">{{typeLabel}}</div>
              {{#if description}}
              <div class="vox-chronicle-entity-description">{{description}}</div>
              {{/if}}
            </div>
            <div class="vox-chronicle-entity-actions">
              <button type="button"
                      class="vox-chronicle-btn-edit"
                      data-action="edit-description"
                      data-entity-type="locations"
                      data-entity-index="{{index}}"
                      title="{{../i18n.editDescription}}">
                <i class="fa-solid fa-edit"></i>
              </button>
              <button type="button"
                      class="vox-chronicle-btn-generate"
                      data-action="generate-portrait"
                      data-entity-type="locations"
                      data-entity-index="{{index}}"
                      {{#if isGeneratingImage}}disabled{{/if}}
                      title="{{../i18n.generatePortrait}}">
                <i class="fa-solid {{#if isGeneratingImage}}fa-spinner fa-spin{{else}}fa-image{{/if}}"></i>
              </button>
            </div>
            {{#if isGeneratingImage}}
            <div class="vox-chronicle-entity-image-placeholder">
              <i class="fa-solid fa-spinner fa-spin"></i>
              <span class="vox-chronicle-placeholder-text">{{../i18n.generating}}</span>
            </div>
            {{else}}
              {{#if imageUrl}}
              <div class="vox-chronicle-entity-preview-image">
                <img src="{{imageUrl}}" alt="{{name}}" />
              </div>
              {{/if}}
            {{/if}}
          </div>
          {{/each}}
        </div>
      </div>
      {{/if}}

      {{!-- Items section --}}
      {{#if hasItems}}
      <div class="vox-chronicle-entity-section">
        <div class="vox-chronicle-section-header" data-action="toggle-section">
          <i class="fa-solid fa-chevron-down vox-chronicle-section-toggle"></i>
          <span class="vox-chronicle-section-title">{{i18n.items}}</span>
          <span class="vox-chronicle-section-count">({{items.length}})</span>
        </div>
        <div class="vox-chronicle-section-content">
          {{#each items}}
          <div class="vox-chronicle-entity-row {{#if selected}}vox-chronicle-selected{{/if}}">
            <div class="vox-chronicle-entity-select">
              <input type="checkbox"
                     data-entity-key="{{key}}"
                     {{#if selected}}checked{{/if}} />
            </div>
            <div class="vox-chronicle-entity-info">
              <div class="vox-chronicle-entity-name">{{name}}</div>
              <div class="vox-chronicle-entity-type">{{typeLabel}}</div>
              {{#if description}}
              <div class="vox-chronicle-entity-description">{{description}}</div>
              {{/if}}
            </div>
            <div class="vox-chronicle-entity-actions">
              <button type="button"
                      class="vox-chronicle-btn-edit"
                      data-action="edit-description"
                      data-entity-type="items"
                      data-entity-index="{{index}}"
                      title="{{../i18n.editDescription}}">
                <i class="fa-solid fa-edit"></i>
              </button>
              <button type="button"
                      class="vox-chronicle-btn-generate"
                      data-action="generate-portrait"
                      data-entity-type="items"
                      data-entity-index="{{index}}"
                      {{#if isGeneratingImage}}disabled{{/if}}
                      title="{{../i18n.generatePortrait}}">
                <i class="fa-solid {{#if isGeneratingImage}}fa-spinner fa-spin{{else}}fa-image{{/if}}"></i>
              </button>
            </div>
            {{#if isGeneratingImage}}
            <div class="vox-chronicle-entity-image-placeholder">
              <i class="fa-solid fa-spinner fa-spin"></i>
              <span class="vox-chronicle-placeholder-text">{{../i18n.generating}}</span>
            </div>
            {{else}}
              {{#if imageUrl}}
              <div class="vox-chronicle-entity-preview-image">
                <img src="{{imageUrl}}" alt="{{name}}" />
              </div>
              {{/if}}
            {{/if}}
          </div>
          {{/each}}
        </div>
      </div>
      {{/if}}

      {{!-- Relationships section --}}
      {{#if hasRelationships}}
      <div class="vox-chronicle-entity-section vox-chronicle-relationships-section">
        <div class="vox-chronicle-section-header" data-action="toggle-section">
          <i class="fa-solid fa-chevron-down vox-chronicle-section-toggle"></i>
          <span class="vox-chronicle-section-title">{{i18n.relationships}}</span>
          <span class="vox-chronicle-section-count">({{relationships.length}})</span>
          <button type="button"
                  class="vox-chronicle-btn-view-graph"
                  data-action="view-graph"
                  title="{{i18n.viewGraph}}">
            <i class="fa-solid fa-project-diagram"></i>
            <span>{{i18n.viewGraph}}</span>
          </button>
        </div>
        <div class="vox-chronicle-section-content">
          <div class="vox-chronicle-relationships-description">
            <p>{{i18n.relationshipsDescription}}</p>
          </div>
          {{#each relationships}}
          <div class="vox-chronicle-relationship-row {{#if selected}}vox-chronicle-selected{{/if}}">
            <div class="vox-chronicle-relationship-select">
              <input type="checkbox"
                     data-entity-key="{{key}}"
                     {{#if selected}}checked{{/if}} />
            </div>
            <div class="vox-chronicle-relationship-info">
              <div class="vox-chronicle-relationship-entities">
                <span class="vox-chronicle-source-entity">{{sourceEntity}}</span>
                <i class="fa-solid fa-arrow-right"></i>
                <span class="vox-chronicle-target-entity">{{targetEntity}}</span>
              </div>
              <div class="vox-chronicle-relationship-type-label">
                <i class="fa-solid fa-tag"></i>
                <span>{{typeLabel}}</span>
              </div>
              {{#if description}}
              <div class="vox-chronicle-relationship-description">{{description}}</div>
              {{/if}}
              {{#if confidence}}
              <div class="vox-chronicle-relationship-confidence">
                <i class="fa-solid fa-star"></i>
                <span>{{../i18n.confidenceLabel}} {{confidence}}/10</span>
              </div>
              {{/if}}
            </div>
          </div>
          {{/each}}
        </div>
      </div>
      {{/if}}

    </div>
    {{else}}
    {{!-- No entities message --}}
    <div class="vox-chronicle-no-entities">
      <i class="fa-solid fa-info-circle"></i>
      <span>{{i18n.noEntities}}</span>
    </div>
    {{/if}}
  {{/if}}

  {{!-- Action buttons --}}
  <div class="vox-chronicle-form-footer">
    {{!-- Review mode actions --}}
    {{#if isReview}}
    <div class="vox-chronicle-selection-actions">
      <button type="button"
              class="vox-chronicle-btn-select-all"
              data-action="select-all"
              {{#if isAllSelected}}disabled{{/if}}>
        <i class="fa-solid fa-check-square"></i>
        <span>{{i18n.selectAll}}</span>
      </button>
      <button type="button"
              class="vox-chronicle-btn-deselect-all"
              data-action="deselect-all"
              {{#if isNoneSelected}}disabled{{/if}}>
        <i class="fa-solid fa-square"></i>
        <span>{{i18n.deselectAll}}</span>
      </button>
    </div>
    <div class="vox-chronicle-form-actions">
      <button type="button"
              class="vox-chronicle-btn-skip"
              data-action="skip-all">
        <i class="fa-solid fa-forward"></i>
        <span>{{i18n.skip}}</span>
      </button>
      <button type="button"
              class="vox-chronicle-btn-confirm"
              data-action="confirm-create"
              {{#if isNoneSelected}}disabled{{/if}}
              {{#unless isKankaConfigured}}disabled{{/unless}}>
        <i class="fa-solid fa-cloud-upload-alt"></i>
        <span>{{i18n.create}} ({{selectedCount}})</span>
      </button>
    </div>
    {{/if}}

    {{!-- Creating mode (no buttons, just progress) --}}
    {{#if isCreating}}
    <div class="vox-chronicle-form-actions vox-chronicle-creating">
      <span class="vox-chronicle-creating-message">{{i18n.creating}}</span>
    </div>
    {{/if}}

    {{!-- Complete/Error mode actions --}}
    {{#if isComplete}}
    <div class="vox-chronicle-form-actions">
      <button type="button"
              class="vox-chronicle-btn-close"
              data-action="close">
        <i class="fa-solid fa-times"></i>
        <span>{{i18n.close}}</span>
      </button>
    </div>
    {{/if}}

    {{#if isError}}
    <div class="vox-chronicle-form-actions">
      <button type="button"
              class="vox-chronicle-btn-retry"
              data-action="retry">
        <i class="fa-solid fa-redo"></i>
        <span>{{i18n.retry}}</span>
      </button>
      <button type="button"
              class="vox-chronicle-btn-close"
              data-action="close">
        <i class="fa-solid fa-times"></i>
        <span>{{i18n.close}}</span>
      </button>
    </div>
    {{/if}}
  </div>
</div>
