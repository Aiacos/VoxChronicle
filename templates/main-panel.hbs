<div class="vox-chronicle-panel" id="vox-chronicle-main-panel">
  {{!-- Config Warning --}}
  {{#unless isConfigured}}
  <div class="vox-chronicle-panel__warning">
    <i class="fa-solid fa-exclamation-triangle"></i>
    {{localize "VOXCHRONICLE.Panel.ConfigWarning"}}
  </div>
  {{/unless}}

  {{!-- Status Badges --}}
  <div class="vox-chronicle-panel__badges">
    <span class="vox-chronicle-badge {{#if isConfigured}}active{{else}}inactive{{/if}}" title="OpenAI API">
      <i class="fa-solid fa-robot"></i> AI
    </span>
    <span class="vox-chronicle-badge {{#if hasRAG}}active{{else}}inactive{{/if}}" title="RAG Knowledge Base">
      <i class="fa-solid fa-database"></i> RAG
    </span>
    <span class="vox-chronicle-badge {{#if kankaConfigured}}active{{else}}inactive{{/if}}" title="Kanka Integration">
      <i class="fa-solid fa-cloud-upload-alt"></i> KANKA
    </span>
  </div>

  {{!-- Journal Confirmation Banner --}}
  {{#unless isRecording}}
  <div class="vox-chronicle-journal-confirmation">
    {{#if hasJournalSelected}}
      <span class="vox-chronicle-journal-confirmation__label">
        <i class="fa-solid fa-book"></i>
        {{localize "VOXCHRONICLE.Panel.Adventure"}}: <strong>{{adventureName}}</strong>
        {{#if supplementaryCount}}
          (+ {{supplementaryCount}} {{localize "VOXCHRONICLE.Panel.Supplementary"}})
        {{/if}}
      </span>
      {{#if isJournalTooShort}}
      <div class="vox-chronicle-journal-confirmation__warning">
        <i class="fa-solid fa-exclamation-triangle"></i>
        {{localize "VOXCHRONICLE.Panel.JournalTooShort"}}
      </div>
      {{/if}}
      {{#if isJournalTooLong}}
      <div class="vox-chronicle-journal-confirmation__warning">
        <i class="fa-solid fa-exclamation-triangle"></i>
        {{localize "VOXCHRONICLE.Panel.JournalTooLong"}}
      </div>
      {{/if}}
    {{else}}
      <span class="vox-chronicle-journal-confirmation__label">
        <i class="fa-solid fa-book"></i>
        {{localize "VOXCHRONICLE.Panel.NoJournalSelected"}}
      </span>
    {{/if}}
    <div class="vox-chronicle-journal-confirmation__actions">
      <button data-action="change-journal" class="vox-chronicle-btn--small">
        <i class="fa-solid fa-pen"></i>
        {{localize "VOXCHRONICLE.Panel.ChangeJournal"}}
      </button>
    </div>
  </div>
  {{/unless}}

  {{!-- Header: Recording Controls --}}
  <div class="vox-chronicle-panel__header">
    <div class="vox-chronicle-panel__controls">
      <button data-action="toggle-recording" {{#if isProcessing}}disabled{{/if}}>
        <i class="fa-solid {{#if isRecording}}fa-stop{{else}}fa-circle{{/if}}"></i>
        {{#if isRecording}}{{localize "VOXCHRONICLE.Panel.Stop"}}{{else}}{{localize "VOXCHRONICLE.Panel.Record"}}{{/if}}
      </button>
      {{#if isRecording}}
      <button data-action="toggle-pause">
        <i class="fa-solid {{#if isPaused}}fa-play{{else}}fa-pause{{/if}}"></i>
      </button>
      {{/if}}
      <span class="vox-chronicle-panel__duration">{{duration}}</span>
    </div>
    {{#if isRecording}}
    <div class="vox-chronicle-panel__level-meter">
      <div class="vox-chronicle-panel__level-bar" style="width: {{audioLevel}}%"></div>
    </div>
    {{/if}}

    {{#if statusMessage}}
    <div class="vox-chronicle-panel__status-msg">
      <i class="fa-solid fa-circle-notch fa-spin"></i> {{statusMessage}}
    </div>
    {{/if}}
    <div class="vox-chronicle-panel__status">
      <span class="vox-chronicle-panel__mode-badge vox-chronicle-panel__mode-badge--{{transcriptionMode}}">
        {{transcriptionMode}}
      </span>
      {{#if currentChapter}}
      <span class="vox-chronicle-panel__chapter" title="{{currentChapter.path}}">
        <i class="fa-solid fa-book"></i> {{currentChapter.title}}
      </span>
      {{/if}}
    </div>
  </div>

  {{!-- Chapter Navigation Bar (visible during live mode) --}}
  {{#if isRecording}}
  <div class="vox-chronicle-chapter-nav">
    <button data-action="prev-chapter" {{#unless prevChapter}}disabled{{/unless}} title="{{prevChapter}}">
      <i class="fa-solid fa-chevron-left"></i>
    </button>
    <span class="vox-chronicle-chapter-nav__title">
      <i class="fa-solid fa-bookmark"></i>
      {{#if chapterNavTitle}}{{chapterNavTitle}}{{else}}{{localize "VOXCHRONICLE.Panel.NoChapter"}}{{/if}}
    </span>
    <span class="vox-chronicle-index-health vox-chronicle-index-health--{{indexStatus}}"></span>
    <button data-action="next-chapter" {{#unless nextChapter}}disabled{{/unless}} title="{{nextChapter}}">
      <i class="fa-solid fa-chevron-right"></i>
    </button>
  </div>
  {{/if}}

  {{!-- 6 Tab Navigation --}}
  <nav class="vox-chronicle-panel__tabs">
    <button class="vox-chronicle-tab {{#if (eq activeTab 'live')}}vox-chronicle-tab--active{{/if}}" data-tab="live">{{localize "VOXCHRONICLE.Panel.TabLive"}}</button>
    <button class="vox-chronicle-tab {{#if (eq activeTab 'chronicle')}}vox-chronicle-tab--active{{/if}}" data-tab="chronicle">{{localize "VOXCHRONICLE.Panel.TabChronicle"}}</button>
    <button class="vox-chronicle-tab {{#if (eq activeTab 'images')}}vox-chronicle-tab--active{{/if}}" data-tab="images">{{localize "VOXCHRONICLE.Panel.TabImages"}}</button>
    <button class="vox-chronicle-tab {{#if (eq activeTab 'transcript')}}vox-chronicle-tab--active{{/if}}" data-tab="transcript">{{localize "VOXCHRONICLE.Panel.TabTranscript"}}</button>
    <button class="vox-chronicle-tab {{#if (eq activeTab 'entities')}}vox-chronicle-tab--active{{/if}}" data-tab="entities">{{localize "VOXCHRONICLE.Panel.TabEntities"}}</button>
    <button class="vox-chronicle-tab {{#if (eq activeTab 'analytics')}}vox-chronicle-tab--active{{/if}}" data-tab="analytics">{{localize "VOXCHRONICLE.Panel.TabAnalytics"}}</button>
  </nav>

  {{!-- Tab Content Panes --}}
  <div class="vox-chronicle-panel__content">
    <div class="vox-chronicle-tab-pane" data-tab-pane="live" {{#unless (eq activeTab 'live')}}hidden{{/unless}}>
      {{#if suggestions.length}}
      <div class="vox-chronicle-panel__suggestions">
        {{#each suggestions}}
        <div class="vox-chronicle-suggestion">
          <span class="vox-chronicle-suggestion__type">{{this.type}}</span>
          <p>{{this.content}}</p>
        </div>
        {{/each}}
      </div>
      {{else}}
      <p class="vox-chronicle-panel__empty">{{localize "VOXCHRONICLE.Panel.NoSuggestions"}}</p>
      {{/if}}

      {{!-- RAG Indexing Status & Controls --}}
      <div class="vox-chronicle-rag-status">
        <div class="vox-chronicle-rag-status__header">
          <h4><i class="fa-solid fa-database"></i> {{localize "VOXCHRONICLE.RAG.IndexStatus"}}</h4>
          <span class="vox-chronicle-rag-status__badge vox-chronicle-rag-status__badge--{{ragStatus}}">
            {{#if ragEnabled}}
              {{#if (eq ragStatus 'indexing')}}
                <i class="fa-solid fa-sync fa-spin"></i> {{localize "VOXCHRONICLE.RAG.IndexBuilding"}}
              {{else if (eq ragStatus 'indexed')}}
                <i class="fa-solid fa-check"></i> {{localize "VOXCHRONICLE.RAG.IndexReady"}}
              {{else}}
                <i class="fa-solid fa-circle"></i> {{localize "VOXCHRONICLE.RAG.IndexEmpty"}}
              {{/if}}
            {{else}}
              <i class="fa-solid fa-times-circle"></i> {{localize "VOXCHRONICLE.RAG.Disabled"}}
            {{/if}}
          </span>
        </div>

        {{#if ragEnabled}}
          {{!-- Indexing Progress Bar --}}
          {{#if (eq ragStatus 'indexing')}}
          <div class="vox-chronicle-rag-status__progress">
            <div class="vox-chronicle-rag-status__progress-bar" style="width: {{ragProgress}}%"></div>
            <span class="vox-chronicle-rag-status__progress-text">{{ragProgressText}}</span>
          </div>
          {{/if}}

          {{!-- RAG Statistics --}}
          <div class="vox-chronicle-rag-status__stats">
            <div class="vox-chronicle-rag-status__stat">
              <i class="fa-solid fa-cubes"></i>
              <span class="vox-chronicle-rag-status__stat-label">{{localize "VOXCHRONICLE.RAG.TotalVectors"}}</span>
              <span class="vox-chronicle-rag-status__stat-value">{{ragVectorCount}}</span>
            </div>
            <div class="vox-chronicle-rag-status__stat">
              <i class="fa-solid fa-hdd"></i>
              <span class="vox-chronicle-rag-status__stat-label">{{localize "VOXCHRONICLE.RAG.MemoryUsage"}}</span>
              <span class="vox-chronicle-rag-status__stat-value">{{ragStorageUsage}}</span>
            </div>
            {{#if ragLastIndexed}}
            <div class="vox-chronicle-rag-status__stat">
              <i class="fa-solid fa-clock"></i>
              <span class="vox-chronicle-rag-status__stat-label">{{localize "VOXCHRONICLE.RAG.LastUpdated"}}</span>
              <span class="vox-chronicle-rag-status__stat-value">{{ragLastIndexed}}</span>
            </div>
            {{/if}}
          </div>

          {{!-- RAG Control Buttons --}}
          <div class="vox-chronicle-rag-status__controls">
            <button data-action="rag-build-index" {{#if (eq ragStatus 'indexing')}}disabled{{/if}}>
              <i class="fa-solid fa-hammer"></i> {{localize "VOXCHRONICLE.RAG.RebuildIndex"}}
            </button>
            <button class="vox-chronicle-btn--danger" data-action="rag-clear-index" {{#unless ragVectorCount}}disabled{{/unless}} {{#if (eq ragStatus 'indexing')}}disabled{{/if}}>
              <i class="fa-solid fa-trash-alt"></i> {{localize "VOXCHRONICLE.RAG.ClearIndex"}}
            </button>
          </div>
        {{else}}
          <p class="vox-chronicle-rag-status__disabled-hint">
            {{localize "VOXCHRONICLE.RAG.EnableHint"}}
          </p>
        {{/if}}
      </div>
    </div>

    <div class="vox-chronicle-tab-pane" data-tab-pane="chronicle" {{#unless (eq activeTab 'chronicle')}}hidden{{/unless}}>
      <div class="vox-chronicle-panel__actions">
        <button data-action="process-session" {{#unless hasTranscript}}disabled{{/unless}} {{#if isProcessing}}disabled{{/if}}>
          {{#if isProcessing}}
            <i class="fa-solid fa-spinner fa-spin"></i> {{localize "VOXCHRONICLE.Panel.Processing"}}
          {{else}}
            <i class="fa-solid fa-cogs"></i> {{localize "VOXCHRONICLE.Panel.ProcessSession"}}
          {{/if}}
        </button>
        <button data-action="publish-kanka" {{#unless hasEntities}}disabled{{/unless}}>
          <i class="fa-solid fa-upload"></i> {{localize "VOXCHRONICLE.Panel.PublishToKanka"}}
        </button>
      </div>

      {{#if hasChronicleDraft}}
      <div class="vox-chronicle-panel__preview">
        <h4>{{localize "VOXCHRONICLE.Panel.ChroniclePreview"}}</h4>
        <div class="vox-chronicle-preview-content">
          {{!-- Safe: chronicleDraft is sanitized via sanitizeHtml() in MainPanel._prepareContext --}}
          {{{chronicleDraft}}}
        </div>
      </div>
      {{/if}}
    </div>

    <div class="vox-chronicle-tab-pane" data-tab-pane="images" {{#unless (eq activeTab 'images')}}hidden{{/unless}}>
      <button data-action="generate-image">
        <i class="fa-solid fa-image"></i> {{localize "VOXCHRONICLE.Panel.GenerateImage"}}
      </button>
      <div class="vox-chronicle-panel__gallery">
        {{#each images}}
        <div class="vox-chronicle-panel__image-card" data-image-id="{{this.id}}">
          <img src="{{this.src}}" alt="{{this.prompt}}">
        </div>
        {{/each}}
      </div>
    </div>

    <div class="vox-chronicle-tab-pane" data-tab-pane="transcript" {{#unless (eq activeTab 'transcript')}}hidden{{/unless}}>
      <div class="vox-chronicle-panel__transcript">
        {{#each segments}}
        <div class="vox-chronicle-segment">
          <span class="vox-chronicle-segment__speaker">{{this.speaker}}:</span>
          <span class="vox-chronicle-segment__text">{{this.text}}</span>
        </div>
        {{else}}
        <p class="vox-chronicle-panel__empty">{{localize "VOXCHRONICLE.Panel.NoTranscript"}}</p>
        {{/each}}
      </div>
    </div>

    <div class="vox-chronicle-tab-pane" data-tab-pane="entities" {{#unless (eq activeTab 'entities')}}hidden{{/unless}}>
      {{#if entities}}
      <button data-action="review-entities">
        <i class="fa-solid fa-eye"></i> {{localize "VOXCHRONICLE.Panel.ReviewEntities"}}
      </button>
      {{else}}
      <p class="vox-chronicle-panel__empty">{{localize "VOXCHRONICLE.Panel.NoEntities"}}</p>
      {{/if}}
    </div>

    <div class="vox-chronicle-tab-pane" data-tab-pane="analytics" {{#unless (eq activeTab 'analytics')}}hidden{{/unless}}>
      <p class="vox-chronicle-panel__empty">{{localize "VOXCHRONICLE.Panel.NoAnalytics"}}</p>
    </div>
  </div>
</div>
