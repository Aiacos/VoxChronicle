{
  "name": "vox-chronicle",
  "version": "4.1.0",
  "description": "Foundry VTT module that automatically transcribes tabletop RPG sessions and publishes them as adventure chronicles to Kanka",
  "type": "module",
  "main": "scripts/main.mjs",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.js",
    "lint": "eslint scripts/**/*.mjs tests/**/*.js",
    "lint:fix": "eslint scripts/**/*.mjs tests/**/*.js --fix",
    "format": "prettier --write 'scripts/**/*.mjs' 'tests/**/*.js'",
    "format:check": "prettier --check 'scripts/**/*.mjs' 'tests/**/*.js'",
    "validate": "node --check scripts/main.mjs"
  },
  "keywords": [
    "foundry-vtt",
    "foundry-vtt-module",
    "tabletop",
    "rpg",
    "transcription",
    "kanka",
    "openai",
    "audio",
    "chronicle"
  ],
  "author": "VoxChronicle Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aiacos/VoxChronicle.git"
  },
  "bugs": {
    "url": "https://github.com/Aiacos/VoxChronicle/issues"
  },
  "homepage": "https://github.com/Aiacos/VoxChronicle#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-jsdoc": "^62.5.4",
    "jsdom": "^24.0.0",
    "prettier": "^3.8.1",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "foundry": {
    "minimum": "13",
    "verified": "13",
    "maximum": "13"
  }
}
